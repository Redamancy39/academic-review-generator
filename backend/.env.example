# =============================================================================
# API Keys 配置说明
# =============================================================================
#
# 1. 复制此文件为 .env
#    cp .env.example .env
#
# 2. 填入你的 API Keys
#
# =============================================================================

# -----------------------------------------------------------------------------
# 阿里云 DashScope API Key (必需)
# -----------------------------------------------------------------------------
# 获取方式: https://dashscope.console.aliyun.com/apiKey
# 格式: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 用途: 用于调用通义千问等大模型
DASHSCOPE_API_KEY=sk-c0701272f9444c8a9c57867ac20cba62

# -----------------------------------------------------------------------------
# Web of Science API Key (可选)
# -----------------------------------------------------------------------------
# 获取方式: https://developer.clarivate.com/apis/wos-starter
# 格式: 由 Clarivate 提供，通常为字母数字组合
# 用途: 用于检索 Web of Science 学术文献数据库
# 如果没有此 Key，系统会自动使用免费的 OpenAlex、Crossref、PubMed
WOS_API_KEY=your-wos-api-key-here

# =============================================================================
# 模型配置
# =============================================================================

# 模型名称 (格式: provider/model-name)
MODEL_NAME=openai/qwen3.5-plus

# 模型 API 地址 (阿里云 DashScope OpenAI 兼容接口)
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# =============================================================================
# 服务配置
# =============================================================================

# WOS API 基础地址
WOS_API_BASE=https://api.clarivate.com/apis/wos-starter/v1/documents

# 服务监听地址
HOST=0.0.0.0

# 服务端口
PORT=8000

# 调试模式
DEBUG=false
